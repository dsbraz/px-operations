@page "/health"
@using PxOperations.BlazorWasm.Api

<div class="health-header">
    <div class="health-header-title">Operations PX · Saúde de Projetos</div>
    <a class="health-header-link" href="/health/new">↗ Formulário do Líder</a>
</div>

<HealthStatsBar TotalProjects="@summary?.TotalProjects"
                AverageScore="@summary?.AverageScore"
                CriticalCount="@summary?.CriticalCount"
                NoResponseCount="@summary?.NoResponseCount" />

<HealthToolbar SearchTerm="@searchTerm" OnSearchChanged="OnSearchChanged"
               FilterDc="@filterDc" OnFilterDcChanged="OnFilterDcChanged"
               FilterScore="@filterScore" OnFilterScoreChanged="OnFilterScoreChanged"
               ActiveTab="@activeTab" OnTabChanged="OnTabChanged" />

@if (isLoading)
{
    <div style="text-align:center;padding:60px;color:var(--muted)">Carregando…</div>
}
else if (activeTab == "dash")
{
    <HealthDashboardView Summary="@summary" Entries="@FilteredEntries" />
}
else
{
    <HealthProjectsView Entries="@FilteredEntries" />
}
