@using PxOperations.BlazorWasm.Api

<div class="toolbar">
    <div class="search-wrap">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
        </svg>
        <input type="text" value="@SearchTerm" @oninput="OnSearchChanged" placeholder="Buscar marco ou projeto..." />
    </div>
    <select value="@FilterDc" @onchange="OnDcChanged">
        <option value="">Todos os DCs</option>
        @foreach (var dc in DeliveryCenters)
        {
            <option value="@dc">@dc</option>
        }
    </select>
    <select value="@FilterType" @onchange="OnTypeChanged">
        <option value="">Todos os Tipos</option>
        @foreach (var type in MilestoneTypes)
        {
            <option value="@type">@type</option>
        }
    </select>
    <select value="@FilterProjectId" @onchange="OnProjectChanged">
        <option value="">Todos os Projetos</option>
        @foreach (var project in Projects.OrderBy(p => p.Name))
        {
            <option value="@project.Id.ToString()">@project.Name</option>
        }
    </select>
    <div class="view-tabs">
        <button class="vtab @(ActiveView == "semana" ? "active" : "")" @onclick='() => OnViewChanged.InvokeAsync("semana")'>Semana</button>
        <button class="vtab @(ActiveView == "calendario" ? "active" : "")" @onclick='() => OnViewChanged.InvokeAsync("calendario")'>Mês</button>
    </div>
</div>

<div class="tipo-legend">
    @foreach (var type in MilestoneTypes)
    {
        <span class="tbadge @TypeCss(type)">@type</span>
    }
</div>
