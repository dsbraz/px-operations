@using PxOperations.BlazorWasm.Api

<div style="padding:0 40px 60px;">
    <div class="ph-proj-head">
        <span>Projeto</span><span>DC · DM</span><span>Última resposta</span>
        <span>Nota</span><span>Status</span><span></span>
    </div>
    <div>
        @if (!ProjectGroups.Any())
        {
            <div style="text-align:center;padding:60px;color:var(--muted);font-size:13px">Nenhum projeto encontrado</div>
        }
        else
        {
            @foreach (var group in ProjectGroups)
            {
                var latest = group.Entries.OrderByDescending(e => e.Week).First();
                var isOpen = expandedProjects.Contains(group.ProjectId);
                <div class="ph-proj-row">
                    <div class="ph-proj-row-head" @onclick="() => ToggleProject(group.ProjectId)">
                        <div>
                            <div class="ph-proj-name">@latest.ProjectName</div>
                            <div class="ph-proj-cli">@latest.ProjectClient</div>
                        </div>
                        <div>
                            <div class="dc-tag">@latest.ProjectDc</div>
                            <div style="font-size:10px;color:var(--muted);margin-top:4px">@latest.ProjectDeliveryManager</div>
                        </div>
                        <div style="font-family:'Space Mono',monospace;font-size:10px;color:var(--muted)">@FormatWeek(latest.Week)</div>
                        <div><span class="score-badge @ScoreClass(latest.Score)">@latest.Score/10</span></div>
                        <div style="font-size:10px;font-weight:700;color:var(--green)">✓ Em dia</div>
                        <div class="ph-proj-toggle" style="@(isOpen ? "transform:rotate(180deg)" : "")">▾</div>
                    </div>
                    <div class="ph-proj-body @(isOpen ? "open" : "")">
                        <div class="ph-proj-grid">
                            @foreach (var entry in group.Entries.OrderByDescending(e => e.Week))
                            {
                                <div class="ph-resp-card">
                                    <div style="display:flex;justify-content:space-between;margin-bottom:10px">
                                        <div>
                                            <div class="ph-resp-sem">Semana @FormatWeek(entry.Week)</div>
                                            @if (entry.SubProject is not null) { <div style="font-size:10px;color:var(--purple);font-weight:600;margin-top:2px">@entry.SubProject</div> }
                                        </div>
                                        <span class="score-badge @ScoreClass(entry.Score)">@entry.Score/10</span>
                                    </div>
                                    <div style="font-size:10px;color:var(--muted);margin-bottom:6px">Práticas: @entry.PracticesCount/5</div>
                                    <div class="ph-resp-dims">
                                        <div class="ph-resp-dim"><span style="color:var(--muted)">Escopo</span><span style="display:flex;align-items:center;gap:5px"><span class="rag-dot-inline @RagDotClass(entry.Scope)"></span></span></div>
                                        <div class="ph-resp-dim"><span style="color:var(--muted)">Cronograma</span><span style="display:flex;align-items:center;gap:5px"><span class="rag-dot-inline @RagDotClass(entry.Schedule)"></span></span></div>
                                        <div class="ph-resp-dim"><span style="color:var(--muted)">Qualidade</span><span style="display:flex;align-items:center;gap:5px"><span class="rag-dot-inline @RagDotClass(entry.Quality)"></span></span></div>
                                        <div class="ph-resp-dim"><span style="color:var(--muted)">Satisfação</span><span style="display:flex;align-items:center;gap:5px"><span class="rag-dot-inline @RagDotClass(entry.Satisfaction)"></span></span></div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(entry.Highlights))
                                    {
                                        <div class="ph-resp-obs">"@entry.Highlights"</div>
                                    }
                                    <div class="ph-resp-tags">
                                        @if (entry.ExpansionOpportunity) { <span class="ph-etag g">↗ Expansão</span> }
                                        @if (entry.ActionPlanNeeded) { <span class="ph-etag o">⚑ Plano de ação</span> }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
