@using PxOperations.BlazorWasm.Api

<div class="renov-view">

    <div class="renov-controls">
        <select @bind="renovYear">
            <option value="2025">2025</option>
            <option value="2026">2026</option>
            <option value="2027">2027</option>
        </select>
        <select @bind="renovPeriod">
            <option value="ano">Ano completo</option>
            <option value="q1">Q1 (Jan–Mar)</option>
            <option value="q2">Q2 (Abr–Jun)</option>
            <option value="q3">Q3 (Jul–Set)</option>
            <option value="q4">Q4 (Out–Dez)</option>
        </select>
        <select @bind="renovDc">
            <option value="">Todos os DCs</option>
            <option value="DC1">DC1</option>
            <option value="DC2">DC2</option>
            <option value="DC3">DC3</option>
            <option value="DC4">DC4</option>
            <option value="DC5">DC5</option>
            <option value="DC6">DC6</option>
        </select>

        <div class="renov-indicator">
            <div class="ri-main">
                <div class="ri-pct">@CoveragePct%</div>
                <div class="ri-lbl">Cobertura @PeriodLabel @renovYear@(string.IsNullOrEmpty(renovDc) ? "" : $" · {renovDc}")</div>
                <div class="ri-bar-wrap"><div class="ri-bar-fill" style="width:@(CoveragePct)%"></div></div>
            </div>
            <div class="ri-sep"></div>
            <div class="ri-breakdown">
                <div class="ri-item"><div class="ri-num aprov">@Approved</div><div class="ri-sub">Aprovadas</div></div>
                <div class="ri-item"><div class="ri-num andamento">@InProgress</div><div class="ri-sub">Em trat.</div></div>
                <div class="ri-item"><div class="ri-num pend">@Pending</div><div class="ri-sub">Pendentes</div></div>
                <div class="ri-item"><div class="ri-num" style="color:var(--muted)">@NoStatus</div><div class="ri-sub">Sem status</div></div>
            </div>
        </div>
    </div>

    @if (string.IsNullOrEmpty(renovDc))
    {
        <div class="dc-section">
            <div class="sec-label">% de cobertura por DC — @PeriodLabel @renovYear</div>
            <div class="dc-bars-grid">
                @foreach (var bar in DcBars.Where(b => b.Total > 0))
                {
                    <div class="dc-bar-card">
                        <div class="dcb-name">@bar.Dc</div>
                        <div class="bar-track"><div class="bar-fill" style="width:@(bar.Pct)%"></div></div>
                        <div class="dcb-nums">
                            <span style="color:var(--muted);font-size:11px">@bar.WithStatus/@bar.Total com status</span>
                            <span class="dcb-pct">@(bar.Pct)%</span>
                        </div>
                        <div class="dcb-sub">@bar.Approved aprovada@(bar.Approved != 1 ? "s" : "")</div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="cards-section">
        <div class="sec-label">
            Projetos com renova&ccedil;&atilde;o registrada — @PeriodLabel @renovYear
        </div>
        @if (Cards.Any())
        {
            <div class="cards-grid">
                @foreach (var p in Cards)
                {
                    <div class="proj-card highlighted" @onclick="() => OnEdit.InvokeAsync(p.Id)" title="Clique para editar">
                        <div class="pc-left">
                            <div class="pc-name">@p.Name</div>
                            <div class="pc-meta">@(p.Client ?? "—") · <strong>@p.Dc</strong> · @(p.DeliveryManager ?? "—")</div>
                            @if (!string.IsNullOrWhiteSpace(p.RenewalObservation))
                            {
                                <div class="pc-obs">@p.RenewalObservation</div>
                            }
                        </div>
                        <div class="pc-right">
                            <span class="rbadge @ProjectBadgeHelper.GetRenewalBadgeClass(p.Renewal)">
                                @ProjectBadgeHelper.GetRenewalIcon(p.Renewal) @p.Renewal
                            </span>
                            @ProjectBadgeHelper.FormatDate(p.EndDate)
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty" style="padding:40px">
                <p style="font-size:13px;font-weight:600;color:var(--muted)">
                    Nenhuma renova&ccedil;&atilde;o registrada para este per&iacute;odo
                </p>
            </div>
        }
    </div>

</div>
