@page "/projects"

<PageTitle>Base de Projetos · Operations PX</PageTitle>

<!-- PAGE ACTIONS BAR -->
<div class="page-actions-bar">
    <button class="btn btn-ghost">&#8595; Exportar CSV</button>
    <button class="btn btn-purple" @onclick="OpenCreateModal">+ Novo Projeto</button>
</div>

<!-- STATS BAR -->
<div class="stats-bar">
    <div class="stat p">
        <div class="sico p">&#9672;</div>
        <div><div class="sval">@projects.Count</div><div class="slbl">Projetos</div></div>
    </div>
    <div class="stat g">
        <div class="sico g">&#10003;</div>
        <div><div class="sval">@ActiveCount</div><div class="slbl">Em andamento</div></div>
    </div>
    <div class="stat b">
        <div class="sico b">&#9678;</div>
        <div><div class="sval">@ClientCount</div><div class="slbl">Clientes</div></div>
    </div>
    <div class="stat o">
        <div class="sico o">&#9873;</div>
        <div><div class="sval">@ExpiringIn60DaysCount</div><div class="slbl">Vencem em 60d</div></div>
    </div>
    <div class="stat b">
        <div class="sico b">&#8635;</div>
        <div><div class="sval">@RenewingCount</div><div class="slbl">Em renovação</div></div>
    </div>
    <div class="stat g">
        <div class="sico g">&#9733;</div>
        <div><div class="sval">@ApprovedRenewalCount</div><div class="slbl">Aprovadas</div></div>
    </div>
</div>

<!-- TOOLBAR -->
<div class="toolbar">
    <div class="search-wrap">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
        </svg>
        <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Buscar projeto ou cliente..." />
    </div>
    <select @bind="filterDc">
        <option value="">Todos os DCs</option>
        <option value="DC1">DC1</option>
        <option value="DC2">DC2</option>
        <option value="DC3">DC3</option>
        <option value="DC4">DC4</option>
        <option value="DC5">DC5</option>
        <option value="DC6">DC6</option>
    </select>
    <select @bind="filterStatus">
        <option value="">Todos os Status</option>
        <option value="Em andamento">Em andamento</option>
        <option value="Programado">Programado</option>
        <option value="Encerrado">Encerrado</option>
    </select>
    <select @bind="filterType">
        <option value="">Todos os Tipos</option>
        <option value="Squad">Squad</option>
        <option value="Escopo Fechado">Escopo Fechado</option>
        <option value="Alocação">Alocação</option>
    </select>
    <select @bind="filterRenewal">
        <option value="">Todas as Renovações</option>
        <option value="Aprovada">&#10003; Aprovada</option>
        <option value="Em andamento">&#8635; Em andamento</option>
        <option value="Pendente">&#9873; Pendente</option>
        <option value="None">Sem status</option>
    </select>
    <div class="view-tabs">
        <button class="vtab @(activeTab == "lista"      ? "active" : "")" @onclick='() => activeTab = "lista"'>Lista</button>
        <button class="vtab @(activeTab == "kanban"     ? "active" : "")" @onclick='() => activeTab = "kanban"'>Kanban</button>
        <button class="vtab @(activeTab == "renovacoes" ? "active" : "")" @onclick='() => activeTab = "renovacoes"'>Renovações</button>
    </div>
</div>

<!-- WEEKLY PULSE -->
<div class="pulse-wrap">
    <div class="pulse-header @(pulseOpen ? "" : "collapsed")" @onclick="TogglePulse">
        <div class="pulse-hd-left">
            <div class="pulse-dot"></div>
            <span class="pulse-title">O que mudou essa semana</span>
            <span class="pulse-subtitle">@WeekLabel</span>
        </div>
        <span class="pulse-chevron @(pulseOpen ? "open" : "")">&#9662;</span>
    </div>
    <div class="pulse-body @(pulseOpen ? "open" : "")">
        <div class="pulse-inner">

            <!-- Novos programados -->
            <div class="pulse-card pc-new">
                <div class="pc-head">
                    <div class="pc-icon">&#9672;</div>
                    <div class="pc-count">@PulseNewScheduled.Count</div>
                </div>
                <div class="pc-label">Novos programados</div>
                <div class="pc-items">
                    @if (PulseNewScheduled.Any())
                    {
                        @foreach (var p in PulseNewScheduled.Take(3))
                        {
                            <div class="pc-item">@p.Name</div>
                        }
                        @if (PulseNewScheduled.Count > 3)
                        {
                            <div class="pc-item-more">+@(PulseNewScheduled.Count - 3) mais</div>
                        }
                    }
                    else
                    {
                        <div class="pc-empty">Nenhum esta semana</div>
                    }
                </div>
            </div>

            <!-- Iniciados semana anterior -->
            <div class="pulse-card pc-start">
                <div class="pc-head">
                    <div class="pc-icon">&#9654;</div>
                    <div class="pc-count">@PulseStartedLastWeek.Count</div>
                </div>
                <div class="pc-label">Iniciados semana ant.</div>
                <div class="pc-items">
                    @if (PulseStartedLastWeek.Any())
                    {
                        @foreach (var p in PulseStartedLastWeek.Take(3))
                        {
                            <div class="pc-item">@p.Name</div>
                        }
                        @if (PulseStartedLastWeek.Count > 3)
                        {
                            <div class="pc-item-more">+@(PulseStartedLastWeek.Count - 3) mais</div>
                        }
                    }
                    else
                    {
                        <div class="pc-empty">Nenhum na semana anterior</div>
                    }
                </div>
            </div>

            <!-- Encerrados semana anterior -->
            <div class="pulse-card pc-end">
                <div class="pc-head">
                    <div class="pc-icon">&#9632;</div>
                    <div class="pc-count">@PulseEndedLastWeek.Count</div>
                </div>
                <div class="pc-label">Encerrados semana ant.</div>
                <div class="pc-items">
                    @if (PulseEndedLastWeek.Any())
                    {
                        @foreach (var p in PulseEndedLastWeek.Take(3))
                        {
                            <div class="pc-item">@p.Name</div>
                        }
                        @if (PulseEndedLastWeek.Count > 3)
                        {
                            <div class="pc-item-more">+@(PulseEndedLastWeek.Count - 3) mais</div>
                        }
                    }
                    else
                    {
                        <div class="pc-empty">Nenhum na semana anterior</div>
                    }
                </div>
            </div>

            <!-- Renovações aprovadas -->
            <div class="pulse-card pc-renew">
                <div class="pc-head">
                    <div class="pc-icon">&#10003;</div>
                    <div class="pc-count">@PulseRenewalApproved.Count</div>
                </div>
                <div class="pc-label">Renova&ccedil;&otilde;es aprovadas</div>
                <div class="pc-items">
                    @if (PulseRenewalApproved.Any())
                    {
                        @foreach (var p in PulseRenewalApproved.Take(3))
                        {
                            <div class="pc-item">@p.Name</div>
                        }
                        @if (PulseRenewalApproved.Count > 3)
                        {
                            <div class="pc-item-more">+@(PulseRenewalApproved.Count - 3) mais</div>
                        }
                    }
                    else
                    {
                        <div class="pc-empty">Nenhuma aprovada</div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@if (activeTab == "lista")
{
    <!-- TABLE HEADER -->
    <div class="table-header">
        <div class="th-left">
            <span class="th-label">Projetos</span>
            <span class="th-count">@FilteredProjects.Count @(FilteredProjects.Count == 1 ? "projeto" : "projetos")</span>
        </div>
        <button class="collapse-btn" @onclick="ToggleTable">
            <span>@(tableOpen ? "Minimizar lista" : "Expandir lista")</span>
            <span>@(tableOpen ? "▲" : "▼")</span>
        </button>
    </div>

    <!-- TABLE CONTENT -->
    <div class="table-wrap @(tableOpen ? "open" : "")" style="@(tableOpen ? "" : "display:none")"  >
        @if (isLoading)
        {
            <div class="status-card" style="margin:16px 0">
                <strong>Carregando projetos...</strong>
            </div>
        }
        else if (errorMessage is not null)
        {
            <div class="status-card error" style="margin:16px 0">
                <strong>Erro</strong>
                <p>@errorMessage</p>
            </div>
        }
        else if (!FilteredProjects.Any())
        {
            <div class="empty">
                <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
                    <polygon points="28,4 52,18 52,38 28,52 4,38 4,18" stroke="#4B148C" stroke-width="1.5"/>
                    <polygon points="28,14 42,22 42,34 28,42 14,34 14,22" stroke="#4B148C" stroke-width="1"/>
                </svg>
                <p style="font-weight:700;font-size:14px;margin-bottom:4px">Nenhum projeto encontrado</p>
                <p style="font-size:12px;color:var(--muted2)">Ajuste os filtros ou adicione um novo projeto</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>DC</th>
                        <th>Projeto</th>
                        <th>Tipo</th>
                        <th>Status</th>
                        <th>Início</th>
                        <th>Fim</th>
                        <th>Dias Rest.</th>
                        <th>Renovação</th>
                        <th>DM</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var project in FilteredProjects)
                    {
                        <tr>
                            <td><span class="dc-tag">@project.Dc</span></td>
                            <td>
                                <div class="proj-name">@project.Name</div>
                                <div class="proj-cli">@(project.Client ?? "—")</div>
                            </td>
                            <td><span class="tbadge @GetTypeBadgeClass(project.Type)">@project.Type</span></td>
                            <td>
                                <span class="sbadge @GetStatusBadgeClass(project.Status)">
                                    @GetStatusDot(project.Status) @project.Status
                                </span>
                            </td>
                            <td>@FormatDate(project.StartDate)</td>
                            <td>@FormatDate(project.EndDate)</td>
                            <td>@RenderRemainingDays(project.EndDate)</td>
                            <td>
                                <span class="rbadge @GetRenewalBadgeClass(project.Renewal)">
                                    @GetRenewalIcon(project.Renewal)
                                    @(project.Renewal == "None" ? "—" : project.Renewal)
                                </span>
                            </td>
                            <td class="dm-txt">@(project.DeliveryManager ?? "—")</td>
                            <td>
                                <div class="row-acts">
                                    <button class="ibtn" @onclick="() => OpenEditModal(project.Id)" title="Editar">
                                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </button>
                                    <button class="ibtn del" @onclick="() => DeleteProject(project.Id)" title="Remover">
                                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
else if (activeTab == "kanban")
{
    <!-- KANBAN VIEW -->
    <div class="kanban-wrap">
        <div class="kanban-controls">
            <label>Agrupar por</label>
            <div class="kanban-group-tabs">
                <button class="kgtab @(kanbanGroupBy == "status"  ? "active" : "")" @onclick='() => kanbanGroupBy = "status"'>Status</button>
                <button class="kgtab @(kanbanGroupBy == "renewal" ? "active" : "")" @onclick='() => kanbanGroupBy = "renewal"'>Renova&ccedil;&atilde;o</button>
                <button class="kgtab @(kanbanGroupBy == "dc"      ? "active" : "")" @onclick='() => kanbanGroupBy = "dc"'>DC</button>
            </div>
        </div>
        <div class="kanban-board">
            @foreach (var col in KanbanColumns)
            {
                var colKey = col.Key;
                <div class="kanban-column @col.ColorClass">
                    <div class="kanban-col-header">
                        <span class="kanban-col-title">@col.Label</span>
                        <span class="kanban-col-count">@col.Items.Count</span>
                    </div>
                    <div class="kanban-col-body @(dragOverColumnKey == colKey ? "drag-over" : "")"
                         @ondragover:preventDefault
                         @ondragenter="() => OnDragEnter(colKey)"
                         @ondragleave="() => OnDragLeave(colKey)"
                         @ondrop="() => OnDrop(colKey)">
                        @if (col.Items.Any())
                        {
                            @foreach (var p in col.Items)
                            {
                                var proj = p;
                                <div class="kanban-card @(draggedProject?.Id == proj.Id ? "dragging" : "")"
                                     draggable="true"
                                     @ondragstart="() => OnDragStart(proj)"
                                     @ondragend="OnDragEnd"
                                     @onclick="() => OpenEditModal(proj.Id)">
                                    <div class="kanban-card-top">
                                        <span class="dc-tag">@proj.Dc</span>
                                        <span class="sbadge @GetStatusBadgeClass(proj.Status)">
                                            @GetStatusDot(proj.Status) @proj.Status
                                        </span>
                                    </div>
                                    <div class="kanban-card-name">@proj.Name</div>
                                    <div class="kanban-card-meta">
                                        <span>@(proj.Client ?? "—")</span>
                                        <span class="kanban-card-sep">·</span>
                                        <span class="tbadge @GetTypeBadgeClass(proj.Type)">@proj.Type</span>
                                    </div>
                                    <div class="kanban-card-dates">
                                        @FormatDate(proj.StartDate)
                                        <span class="kanban-card-sep">→</span>
                                        @FormatDate(proj.EndDate)
                                        @RenderRemainingDays(proj.EndDate)
                                    </div>
                                    <div>
                                        <span class="rbadge @GetRenewalBadgeClass(proj.Renewal)">
                                            @GetRenewalIcon(proj.Renewal) @(proj.Renewal == "None" ? "—" : proj.Renewal)
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(proj.DeliveryManager))
                                    {
                                        <div class="kanban-card-dm">@proj.DeliveryManager</div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="kanban-empty">Nenhum projeto</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <!-- RENOVAÇÕES VIEW -->
    <div class="renov-view">

        <!-- CONTROLS + INDICATOR -->
        <div class="renov-controls">
            <select @bind="renovYear">
                <option value="2025">2025</option>
                <option value="2026">2026</option>
                <option value="2027">2027</option>
            </select>
            <select @bind="renovPeriod">
                <option value="ano">Ano completo</option>
                <option value="q1">Q1 (Jan–Mar)</option>
                <option value="q2">Q2 (Abr–Jun)</option>
                <option value="q3">Q3 (Jul–Set)</option>
                <option value="q4">Q4 (Out–Dez)</option>
            </select>
            <select @bind="renovDc">
                <option value="">Todos os DCs</option>
                <option value="DC1">DC1</option>
                <option value="DC2">DC2</option>
                <option value="DC3">DC3</option>
                <option value="DC4">DC4</option>
                <option value="DC5">DC5</option>
                <option value="DC6">DC6</option>
            </select>

            <div class="renov-indicator">
                <div class="ri-main">
                    <div class="ri-pct">@RenovCoveragePct%</div>
                    <div class="ri-lbl">Cobertura @RenovPeriodLabel @renovYear@(string.IsNullOrEmpty(renovDc) ? "" : $" · {renovDc}")</div>
                    <div class="ri-bar-wrap"><div class="ri-bar-fill" style="width:@(RenovCoveragePct)%"></div></div>
                </div>
                <div class="ri-sep"></div>
                <div class="ri-breakdown">
                    <div class="ri-item"><div class="ri-num aprov">@RenovApproved</div><div class="ri-sub">Aprovadas</div></div>
                    <div class="ri-item"><div class="ri-num andamento">@RenovInProgress</div><div class="ri-sub">Em trat.</div></div>
                    <div class="ri-item"><div class="ri-num pend">@RenovPending</div><div class="ri-sub">Pendentes</div></div>
                    <div class="ri-item"><div class="ri-num" style="color:var(--muted)">@RenovNoStatus</div><div class="ri-sub">Sem status</div></div>
                </div>
            </div>
        </div>

        <!-- DC BARS — only when "Todos os DCs" -->
        @if (string.IsNullOrEmpty(renovDc))
        {
            <div class="dc-section">
                <div class="sec-label">% de cobertura por DC — @RenovPeriodLabel @renovYear</div>
                <div class="dc-bars-grid">
                    @foreach (var bar in RenovDcBars.Where(b => b.Total > 0))
                    {
                        <div class="dc-bar-card">
                            <div class="dcb-name">@bar.Dc</div>
                            <div class="bar-track"><div class="bar-fill" style="width:@(bar.Pct)%"></div></div>
                            <div class="dcb-nums">
                                <span style="color:var(--muted);font-size:11px">@bar.WithStatus/@bar.Total com status</span>
                                <span class="dcb-pct">@(bar.Pct)%</span>
                            </div>
                            <div class="dcb-sub">@bar.Approved aprovada@(bar.Approved != 1 ? "s" : "")</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- PROJECT CARDS -->
        <div class="cards-section">
            <div class="sec-label">
                Projetos com renova&ccedil;&atilde;o registrada — @RenovPeriodLabel @renovYear
            </div>
            @if (RenovCards.Any())
            {
                <div class="cards-grid">
                    @foreach (var p in RenovCards)
                    {
                        <div class="proj-card highlighted" @onclick="() => OpenEditModal(p.Id)" title="Clique para editar">
                            <div class="pc-left">
                                <div class="pc-name">@p.Name</div>
                                <div class="pc-meta">@(p.Client ?? "—") · <strong>@p.Dc</strong> · @(p.DeliveryManager ?? "—")</div>
                                @if (!string.IsNullOrWhiteSpace(p.RenewalObservation))
                                {
                                    <div class="pc-obs">@p.RenewalObservation</div>
                                }
                            </div>
                            <div class="pc-right">
                                <span class="rbadge @GetRenewalBadgeClass(p.Renewal)">
                                    @GetRenewalIcon(p.Renewal) @p.Renewal
                                </span>
                                @FormatDate(p.EndDate)
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty" style="padding:40px">
                    <p style="font-size:13px;font-weight:600;color:var(--muted)">
                        Nenhuma renova&ccedil;&atilde;o registrada para este per&iacute;odo
                    </p>
                </div>
            }
        </div>

    </div>
}

<!-- MODAL -->
@if (showModal)
{
    <div class="overlay open" @onclick="CloseModalOnOverlay">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-top">
                <div>
                    <div class="modal-ttl">@(editingProjectId.HasValue ? "Editar Projeto" : "Novo Projeto")</div>
                    <div class="modal-sub">@(editingProjectId.HasValue ? "Atualize os dados do projeto" : "Preencha os dados do projeto")</div>
                </div>
                <button class="mcls" @onclick="CloseModal">&#215;</button>
            </div>

            @if (modalError is not null)
            {
                <div class="status-card error" style="margin-bottom:16px;padding:12px 16px;">
                    <p>@modalError</p>
                </div>
            }

            <div class="fgrid">
                <div class="fg">
                    <label>DC</label>
                    <select @bind="formDc">
                        <option value="DC1">DC1</option>
                        <option value="DC2">DC2</option>
                        <option value="DC3">DC3</option>
                        <option value="DC4">DC4</option>
                        <option value="DC5">DC5</option>
                        <option value="DC6">DC6</option>
                    </select>
                </div>
                <div class="fg">
                    <label>Status do Projeto</label>
                    <select @bind="formStatus">
                        <option value="Em andamento">Em andamento</option>
                        <option value="Programado">Programado</option>
                        <option value="Encerrado">Encerrado</option>
                    </select>
                </div>
                <div class="fg full">
                    <label>Nome do Projeto</label>
                    <input type="text" @bind="formName" placeholder="Ex: Portal CSC" maxlength="200" />
                </div>
                <div class="fg">
                    <label>Cliente</label>
                    <input type="text" @bind="formClient" placeholder="Ex: CPFL" maxlength="200" />
                </div>
                <div class="fg">
                    <label>Tipo</label>
                    <select @bind="formType">
                        <option value="Squad">Squad</option>
                        <option value="Escopo Fechado">Escopo Fechado</option>
                        <option value="Alocação">Alocação</option>
                    </select>
                </div>
                <div class="fg">
                    <label>Início</label>
                    <input type="date" @bind="formStartDate" />
                </div>
                <div class="fg">
                    <label>Fim</label>
                    <input type="date" @bind="formEndDate" />
                </div>
                <div class="fg full">
                    <label>Delivery Manager</label>
                    <select @bind="formDeliveryManager">
                        <option value="">Sem Delivery Manager</option>
                        <option value="Pedro Vieira">Pedro Vieira (DC1)</option>
                        <option value="Flavia de Castro">Flavia de Castro (DC2)</option>
                        <option value="Juliana Pestana">Juliana Pestana (DC3)</option>
                        <option value="Matheus Sieiro">Matheus Sieiro (DC4)</option>
                        <option value="Filipe Bertoncini">Filipe Bertoncini (DC5)</option>
                    </select>
                </div>
                <div class="fg-divider"><span>Renovação</span></div>
                <div class="fg full">
                    <label>Status de Renovação</label>
                    <select @bind="formRenewal">
                        <option value="None">— Sem status</option>
                        <option value="Pendente">&#9873; Pendente</option>
                        <option value="Em andamento">&#8635; Em andamento</option>
                        <option value="Aprovada">&#10003; Aprovada</option>
                    </select>
                </div>
                <div class="fg full">
                    <label>Observação sobre renovação</label>
                    <textarea @bind="formRenewalObservation"
                              placeholder="Ex: Proposta enviada, aguardando aprovação do sponsor"
                              maxlength="500"></textarea>
                </div>
            </div>

            <div class="mfoot">
                <button class="btn btn-ghost" @onclick="CloseModal">Cancelar</button>
                <button class="btn btn-purple" @onclick="SaveProject" disabled="@isSaving">
                    @(isSaving ? "Salvando..." : "Salvar Projeto")
                </button>
            </div>
        </div>
    </div>
}

<!-- TOAST -->
<div class="toast @(toastMessage is not null ? "show" : "")">
    <span style="color:var(--green);font-size:14px">&#10003;</span>
    <span>@toastMessage</span>
</div>
