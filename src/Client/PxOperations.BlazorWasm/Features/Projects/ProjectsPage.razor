@page "/projects"

<PageTitle>Base de Projetos · Operations PX</PageTitle>

<!-- PAGE ACTIONS BAR -->
<div class="page-actions-bar">
    <button class="btn btn-ghost">&#8595; Exportar CSV</button>
    <button class="btn btn-purple" @onclick="OpenCreateModal">+ Novo Projeto</button>
</div>

<ProjectsStatsBar
    TotalCount="@projects.Count"
    ActiveCount="@ActiveCount"
    ClientCount="@ClientCount"
    ExpiringIn60DaysCount="@ExpiringIn60DaysCount"
    RenewingCount="@RenewingCount"
    ApprovedRenewalCount="@ApprovedRenewalCount" />

<ProjectsToolbar
    DeliveryCenters="@deliveryCenters"
    Statuses="@statuses"
    Types="@projectTypes"
    SearchTerm="@searchTerm"
    FilterDc="@filterDc"
    FilterStatus="@filterStatus"
    FilterType="@filterType"
    FilterRenewal="@filterRenewal"
    ActiveTab="@activeTab"
    OnSearchTermChanged="@(value => searchTerm = value)"
    OnFilterDcChanged="@(value => filterDc = value)"
    OnFilterStatusChanged="@(value => filterStatus = value)"
    OnFilterTypeChanged="@(value => filterType = value)"
    OnFilterRenewalChanged="@(value => filterRenewal = value)"
    OnActiveTabChanged="@(value => activeTab = value)" />

<!-- WEEKLY PULSE -->
<WeeklyPulse Projects="@projects" />

@if (activeTab == "lista")
{
    <ProjectListView
        Projects="@FilteredProjects"
        IsLoading="@isLoading"
        ErrorMessage="@errorMessage"
        OnEdit="@OpenEditModal"
        OnDelete="@DeleteProject" />
}
else if (activeTab == "kanban")
{
    <ProjectKanbanView
        Projects="@FilteredProjects"
        OnEdit="@OpenEditModal"
        OnProjectUpdated="@HandleProjectUpdated"
        OnToast="@ShowToast"
        OnError="@HandleError" />
}
else
{
    <ProjectRenewalsView
        Projects="@FilteredProjects"
        OnEdit="@OpenEditModal" />
}

<!-- MODAL -->
@if (showModal)
{
    <ProjectFormModal
        EditingProject="@editingProject"
        OnClose="@CloseModal"
        OnSaved="@HandleProjectSaved" />
}

<!-- TOAST -->
<div class="toast @(toastMessage is not null ? "show" : "")">
    <span style="color:var(--green);font-size:14px">&#10003;</span>
    <span>@toastMessage</span>
</div>
