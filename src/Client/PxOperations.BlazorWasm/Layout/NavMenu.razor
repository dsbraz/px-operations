@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager NavigationManager

<header class="topbar">
    <div class="logo">
        <img src="images/brq-logo.svg" alt="BRQ" class="brq-logo" />
        <div class="logo-sep"></div>
        <div class="logo-tag">Operations PX</div>
    </div>
    @if (!IsPublicNpsForm)
    {
        <nav>
            <NavLink href="/" Match="NavLinkMatch.All">Projetos</NavLink>
            <NavLink href="/milestones">Marcos</NavLink>
            <NavLink href="/project-health">Saúde</NavLink>
            <NavLink href="/nps">NPS</NavLink>
        </nav>
    }
</header>

@code {
    private bool IsPublicNpsForm
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var pathOnly = relativePath.Split('?', '#')[0].Trim('/');
            var segments = pathOnly.Split('/', StringSplitOptions.RemoveEmptyEntries);

            return segments.Length == 2
                && string.Equals(segments[0], "nps", StringComparison.OrdinalIgnoreCase)
                && Guid.TryParse(segments[1], out _);
        }
    }
}
